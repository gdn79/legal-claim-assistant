# LLM provider: "openai" (default) or "yandex"
LLM_PROVIDER=openai

# OpenAI / OpenAI-compatible API settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.artemox.com/v1
OPENAI_TIMEOUT_SECONDS=300

# Yandex GPT settings (used when LLM_PROVIDER=yandex)
# YANDEX_API_KEY=...
# YANDEX_FOLDER_ID=...
# YANDEX_MODEL=yandexgpt/latest

# Windows example:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Docker example (tesseract is in PATH):
# TESSERACT_CMD=tesseract
TESSERACT_CMD=
OCR_ENABLED=true
OCR_TIMEOUT_SECONDS=90

# Optional: override storage paths.
CASES_DIR=data/cases
TRAINING_DIR=data/training
COURTS_FILE=data/references/arbitration_courts_ru.json
PROMPTS_FILE=data/prompts.json

# Optional company data enrichment by INN via https://www.rusprofile.ru/
RUSPROFILE_ENABLED=true
RUSPROFILE_TIMEOUT_SECONDS=15
